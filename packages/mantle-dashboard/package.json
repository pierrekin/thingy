{
  "name": "@mantle-team/mantle-dashboard",
  "version": "0.0.2",
  "private": false,
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/index.css"
  },
  "files": [
    "src/**",
    "dist/**"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --configLoader runner",
    "preview": "vite preview",
    "check": "bun run check:typecheck && bun run check:lint && bun run check:format && bun run check:organise",
    "check:typecheck": "tsc -b",
    "check:lint": "biome lint .",
    "check:format": "biome format .",
    "check:organise": "biome check --linter-enabled=false --formatter-enabled=false .",
    "fix": "bun run fix:lint && bun run fix:organise && bun run fix:format",
    "fix:lint": "biome lint --write .",
    "fix:format": "biome format --write .",
    "fix:organise": "biome check --linter-enabled=false --formatter-enabled=false --write ."
  },
  "dependencies": {
    "@mantle-team/client": "workspace:*",
    "@mantle-team/mantle-brand": "workspace:*",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
