{
  "name": "mantle",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run packages/mantle/src/index.ts",
    "dev:make-certs": "mkdir -p $HOME/.local/certs && mkcert -cert-file $HOME/.local/certs/localhost+1.pem -key-file $HOME/.local/certs/localhost+1-key.pem localhost mantle-dev.alphen.house",
    "dev:run-caddy": "CERTS_DIR=$HOME/.local/certs caddy run --config packages/mantle-hub/Caddyfile",
    "dev:run-vite": "cd packages/mantle-dashboard && bun run vite",
    "build:dashboard": "cd packages/mantle-dashboard && bun run build && cd ../.. && bun run packages/mantle-hub/scripts/embed-assets.ts",
    "build": "bun run build:dashboard && bun build packages/mantle/src/index.ts --compile --target=${TARGET:-bun} --outfile=${OUTFILE:-dist/mantle}",
    "clean": "rm -f .*.bun-build",
    "docker:build": "docker buildx build --platform linux/amd64,linux/arm64 -t ghcr.io/mantle-team/mantle:latest .",
    "docker:build-local": "docker build -f Dockerfile.dev -t mantle:local .",
    "docker:run-local": "docker run --init -it --rm -p 8080:8080 -v ./config.yaml:/app/config.yaml mantle:local",
    "docker:release": "docker buildx build --platform linux/amd64,linux/arm64 -t ghcr.io/mantle-team/mantle:${VERSION} -t ghcr.io/mantle-team/mantle:latest --push .",
    "version": "bun run scripts/version.ts",
    "manifest:publish": "bun run scripts/publish-manifest.ts",
    "test:e2e": "bun run packages/provider-e2e/run.ts test all",
    "record:missing": "bun run packages/provider-e2e/run.ts test --record missing",
    "record:all": "bun run packages/provider-e2e/run.ts test --record all"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  },
  "dependencies": {
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  }
}
