# Stage 1: Build
FROM --platform=$BUILDPLATFORM oven/bun:1-alpine AS builder
ARG TARGETARCH
WORKDIR /app

COPY package.json bun.lock ./
COPY packages/mantle/package.json packages/mantle/
COPY packages/mantle/web/package.json packages/mantle/web/
COPY packages/provider-proxmox/package.json packages/provider-proxmox/
COPY packages/provider-restic/package.json packages/provider-restic/

RUN bun install

COPY packages packages
COPY tsconfig.json ./

RUN bun run build:web

RUN if [ "$TARGETARCH" = "amd64" ]; then \
      bun build packages/mantle/src/index.ts --compile --target=bun-linux-x64 --outfile dist/mantle; \
    elif [ "$TARGETARCH" = "arm64" ]; then \
      bun build packages/mantle/src/index.ts --compile --target=bun-linux-arm64 --outfile dist/mantle; \
    fi

# Stage 2: Runtime
FROM alpine:3.19
RUN apk add --no-cache libstdc++ libgcc
WORKDIR /app

COPY --from=builder /app/dist/mantle /app/mantle

EXPOSE 8080
ENTRYPOINT ["/app/mantle"]
