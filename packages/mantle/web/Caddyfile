{
	auto_https disable_redirects
	skip_install_trust
	debug
}

:443 {
	tls {$CERTS_DIR}/localhost+1.pem {$CERTS_DIR}/localhost+1-key.pem
	respond 404
}

localhost, mantle-dev.alphen.house {
	tls {$CERTS_DIR}/localhost+1.pem {$CERTS_DIR}/localhost+1-key.pem
	log
	reverse_proxy localhost:8080 {
		transport http {
			versions 1.1
		}
	}
}
